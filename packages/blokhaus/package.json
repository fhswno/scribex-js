{
  "name": "@blokhaus/core",
  "version": "0.1.0",
  "description": "The shadcn of rich text editors — composable, block-based Notion-style editor components for Next.js, built on Lexical.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fhswno/blokhaus-js.git",
    "directory": "packages/blokhaus"
  },
  "homepage": "https://github.com/fhswno/blokhaus-js",
  "bugs": "https://github.com/fhswno/blokhaus-js/issues",
  "keywords": [
    "editor",
    "rich-text",
    "lexical",
    "nextjs",
    "react",
    "notion",
    "block-editor",
    "wysiwyg",
    "text-editor",
    "content-editor",
    "composable",
    "headless"
  ],
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles": "./src/styles/tokens.css"
  },
  "files": [
    "dist",
    "src/styles/tokens.css",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "lexical": ">=0.40.0 <1.0.0",
    "next": ">=14"
  },
  "dependencies": {
    "@lexical/history": "^0.40.0",
    "@lexical/html": "^0.40.0",
    "@lexical/link": "^0.40.0",
    "@lexical/list": "^0.40.0",
    "@lexical/react": "^0.40.0",
    "@lexical/rich-text": "^0.40.0",
    "@lexical/selection": "^0.40.0",
    "@lexical/table": "^0.40.0",
    "@lexical/utils": "^0.40.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.15",
    "shiki": "^3.22.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "lexical": "^0.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
